# =============================================================================
# Helora — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Only TURSO_* variables are needed to switch from local SQLite to Turso cloud.
# All other integrations are optional — the app works without them.

# ── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (default, works out of the box):
DATABASE_URL=file:./db/custom.db

# Turso Cloud Database (set these to switch from local SQLite):
# TURSO_DATABASE_URL=libsql://helora-db-yourname.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Cloudflare R2 (File Storage) ────────────────────────────────────────────
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=helora-uploads
# R2_PUBLIC_URL=https://files.helora.com.br

# ── Ably (Realtime / WebSocket) ─────────────────────────────────────────────
# Server-side (secret):
# ABLY_API_KEY=your-ably-api-key
# Client-side (public — prefixed with NEXT_PUBLIC_):
# NEXT_PUBLIC_ABLY_KEY=your-ably-client-key

# ── Brevo (Transactional Email) ────────────────────────────────────────────
# BREVO_SMTP_USER=your-brevo-smtp-login
# BREVO_SMTP_PASS=your-brevo-smtp-key
# BREVO_FROM_EMAIL=contato@helora.com.br
# BREVO_FROM_NAME=Helora

# ── Asaas (Payment — Brazil) ────────────────────────────────────────────────
# ASAAS_API_KEY=your-asaas-api-key
# ASAAS_ENV=sandbox
# (change ASAAS_ENV to "production" when going live)

# ── Sentry (Error Monitoring) ───────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_DSN=https://xxx@sentry.io/xxx