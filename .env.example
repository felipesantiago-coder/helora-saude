# ── Helora – Variáveis de Ambiente ──
# Copie este arquivo para .env.local e preencha os valores.

# Banco de dados
# Local (desenvolvimento):  file:./db/custom.db
# Produção (Vercel):       URL do banco PostgreSQL (ex: Vercel Postgres, Neon, Supabase)
DATABASE_URL="file:./db/custom.db"

# NextAuth (opcional – necessário se usar autenticação via providers)
# NEXTAUTH_URL="https://seu-dominio.vercel.app"
# NEXTAUTH_SECRET="gerar-um-secret-seguro-com-openssl-rand-base64-32"